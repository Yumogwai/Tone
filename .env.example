# Copy to .env.local (gitignored) and fill in real values. This file is committed
# with KEYS ONLY (no real values).
#
# Tone is fully client-side today and needs NO secrets to run. The slots below are
# placeholders for when the AI/RAG backend is added. In Vite, only VITE_-prefixed
# vars are exposed to the browser — keep real secrets OUT of VITE_ names.

# --- App ---
VITE_APP_ENV=development

# --- AI backend (added later; server-side, NOT VITE_-prefixed) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
